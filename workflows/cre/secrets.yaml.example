# CRE secrets template — NexusFi
# Copy to secrets.yaml and fill in values.
# secrets.yaml is gitignored — NEVER commit it.
#
# Usage in workflow: runtime.getSecret("KEY_NAME").result()
#
# For simulation without real secrets, getSecret() returns empty string.

secretsNames:
  # Required for WF4: Privacy Credit Check
  # Used by ConfidentialHTTPClient (production) or HTTPClient (simulation)
  # to authenticate with the external credit bureau API.
  # CREDIT_API_KEY:
  #   - CREDIT_API_KEY_ALL

  # Required for WF2: AI Credit Scoring (production LLM integration)
  # Used to call Google Gemini or OpenAI for on-chain history analysis.
  # GEMINI_API_KEY:
  #   - GEMINI_API_KEY_ALL

  # Optional: CoinGecko Pro API key for higher rate limits
  # COINGECKO_API_KEY:
  #   - COINGECKO_API_KEY_ALL
