# =====================================================================
# NexusFi .gitignore
# SECURITY FIRST — Never commit secrets, keys, or credentials.
# All sensitive values MUST come from environment variables or
# local gitignored files (.env, secrets.yaml). See .env.example.
# =====================================================================

# Dependencies
node_modules/
.pnpm-store/

# ── Environment & Secrets (NEVER COMMIT) ─────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
secrets/
secrets.yaml
**/secrets.yaml
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.secret
*.credential*
**/serviceAccountKey.json
**/firebase-adminsdk*.json
**/google-credentials*.json

# Wallet / blockchain key files
*.wif
*.seed
**/keypair.json
**/wallet.json
**/identity.json

# ── Build outputs ────────────────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ── IDE / OS ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── Testing ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Soroban / Rust ───────────────────────────────────────────────────
contracts/target/
**/Cargo.lock

# ── CRE / Chainlink ─────────────────────────────────────────────────
nexusfi/

# ── Misc ─────────────────────────────────────────────────────────────
*.tgz
.cache/
.turbo/
