# ==============================================================================
# NexusFi — Environment Variables (Root)
# ==============================================================================
# Copy to .env and fill in values. NEVER commit .env to git.
# ==============================================================================

# --- Backend ---
NODE_ENV=development
PORT=3001
# API_SECRET_KEY=              # Generate: openssl rand -hex 32
# SESSION_SECRET=              # Generate: openssl rand -hex 32 (required in production)

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Stellar / Soroban ---
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
HORIZON_URL=https://horizon-testnet.stellar.org
# SOROBAN_SECRET_KEY=          # Stellar secret key (starts with S, 56 chars)
# DEPLOYER_ADDRESS=            # Deployer public address (admin for all contracts)
# NUSD_RESERVE_ADDRESS=        # Address holding XLM/USDC backing nUSD (Proof of Reserve)

# --- Soroban Contract IDs (deployed on Stellar Testnet) ---
# NUSD_CONTRACT_ID=CDUFIUTO6TH5VLDZ7NWIB2P4WZJ4RIMV4Q6FS44V6LSK6R3BA7U4KZUE
# NBRL_CONTRACT_ID=CBDCRA6I4UAHSQWJL2O7XLXD7BHBG24SEA5DNGM56CIGJETMVIKAV3DS
# CREDIT_SCORE_CONTRACT_ID=CDALW3URIC7F4NJXNMYV5IQ45F2LNCANJBT4AOWFTTIBE4TYK5JBH77J
# CREDIT_LINE_CONTRACT_ID=CAOOW56V4KKK2HNTTXOCL7VXJU7GEFOJLUWCRUYMUNOSHX74TZH7RFJN

# --- MoonPay (On-ramp / Off-ramp) ---
# Get keys at: https://dashboard.moonpay.com
# MOONPAY_PK=pk_test_...       # Publishable key (safe for client)
# MOONPAY_SECRET_KEY=sk_test_... # Secret key for URL signing — NEVER expose
# MOONPAY_WEBHOOK_KEY=          # Webhook signing key for callbacks
# MOONPAY_TREASURY_ADDRESS=     # Stellar address where MoonPay sends USDC (buy flow)
#                               # Webhook mints nUSD to user; treasury receives USDC
MOONPAY_ENV=sandbox             # sandbox | production

# --- Chainlink / CRE ---
# CHAINLINK_OPERATOR_KEY=
# CHAINLINK_OPERATOR_SECRET=

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000
