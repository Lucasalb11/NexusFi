# ==============================================================================
# NexusFi — Environment Variables (Root)
# ==============================================================================
# Copy to .env and fill in values. NEVER commit .env to git.
# ==============================================================================

# --- Backend ---
NODE_ENV=development
PORT=3001
# API_SECRET_KEY=              # Generate: openssl rand -hex 32

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Stellar / Soroban ---
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
HORIZON_URL=https://horizon-testnet.stellar.org
# SOROBAN_SECRET_KEY=          # Stellar secret key (starts with S, 56 chars)
# NUSD_ISSUER_ADDRESS=         # nUSD token issuer public key

# --- MoonPay (On-ramp / Off-ramp) ---
# Get keys at: https://dashboard.moonpay.com
# MOONPAY_PK=pk_test_...       # Publishable key (safe for client)
# MOONPAY_SECRET_KEY=sk_test_... # Secret key for URL signing — NEVER expose
# MOONPAY_WEBHOOK_KEY=          # Webhook signing key for callbacks
MOONPAY_ENV=sandbox             # sandbox | production

# --- Chainlink / CRE ---
# CHAINLINK_OPERATOR_KEY=
# CHAINLINK_OPERATOR_SECRET=

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000
