# ==============================================================================
# NexusFi Backend — Environment Variables
# ==============================================================================
# Copy to .env and fill in values. NEVER commit .env to git.
# ==============================================================================

NODE_ENV=development
PORT=3001

# Stellar / Soroban
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
HORIZON_URL=https://horizon-testnet.stellar.org
# SOROBAN_SECRET_KEY=          # REQUIRED for contract writes — deployer secret key
# DEPLOYER_ADDRESS=            # Deployer public address (admin for all contracts)

# Soroban Contract IDs (Stellar Testnet)
# NUSD_CONTRACT_ID=            # nexusfi_token (nUSD) contract
# NBRL_CONTRACT_ID=            # nexusfi_token (nBRL) contract
# CREDIT_SCORE_CONTRACT_ID=    # credit_score contract
# CREDIT_LINE_CONTRACT_ID=     # credit_line contract

# MoonPay (On-ramp / Off-ramp: PIX, SWIFT, Card, SEPA)
# MOONPAY_PK=pk_test_...       # Publishable key
# MOONPAY_SECRET_KEY=sk_test_... # Secret key — NEVER expose to frontend
# MOONPAY_WEBHOOK_KEY=          # Webhook signing key
MOONPAY_ENV=sandbox             # sandbox | production

# CORS
FRONTEND_URL=http://localhost:3000
